# ===== GENERAL CONFIGURATION =====
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://localhost/dineflow
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
CORS_ORIGIN=http://localhost:5173,http://localhost:8080
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ===== SUPERADMIN CREDENTIALS =====
SUPERADMIN_EMAIL=admin@dineflow.com
SUPERADMIN_PASSWORD=admin123

# ===== FREE IMAGE APIS (RECOMMENDED) =====
# Unsplash - 50 requests/hour free (high quality professional photos)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Pexels - 200 requests/hour free (good quality stock photos)  
PEXELS_API_KEY=your_pexels_api_key_here

# ===== GOOGLE IMAGES API (OPTIONAL - REQUIRES GCP) =====
# Only if you have Google Cloud Platform account
# GOOGLE_API_KEY=your_google_api_key_here
# GOOGLE_SEARCH_ENGINE_ID=your_custom_search_engine_id_here

# ===== OCR & AI SERVICES =====
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Groq API for Menu Extraction (Vision AI)
GROQ_API_KEY=your_groq_api_key_here

# ===== PAYTM PAYMENT GATEWAY (STAGING) =====
PAYTM_MID=your_paytm_merchant_id_here
PAYTM_KEY=your_paytm_merchant_key_here
PAYTM_WEBSITE=WEBSTAGING
PAYTM_CALLBACK_URL=https://your-backend-url.com/api/paytm/callback

# ===== RAZORPAY PAYMENT GATEWAY (OPTIONAL) =====
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
