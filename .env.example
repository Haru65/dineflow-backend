# ===== GENERAL CONFIGURATION =====
NODE_ENV=development
PORT=3000
DATABASE_PATH=D:\DINEFLOWW\data\dineflow.db
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
CORS_ORIGIN=http://localhost:5173,http://localhost:8080
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ===== OCR & AI SERVICES =====
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ===== PAYTM PAYMENT GATEWAY (STAGING) =====
PAYTM_ENVIRONMENT=staging
PAYTM_MID=your_paytm_merchant_id_here
PAYTM_MERCHANT_KEY=your_paytm_merchant_key_here
PAYTM_WEBSITE=WEBSTAGING
PAYTM_INDUSTRY_TYPE=etail
PAYTM_CHANNEL_ID=WEB
PAYTM_CALLBACK_URL=http://localhost:3000/api/payment/paytm/callback

# ===== RAZORPAY PAYMENT GATEWAY (OPTIONAL) =====
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
